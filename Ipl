import pandas as pd
import matplotlib.pyplot as plt
matches = pd.read_csv("matches.csv")
deliveries = pd.read_csv("deliveries.csv")
print("Matches Dataset")
print(matches.head())
print("\nDeliveries Dataset")
print(deliveries.head())
print("\nTotal Matches:", len(matches))
print("\nMatches Won by Teams")
wins = matches["winner"].value_counts()
print(wins)
wins.plot(kind="bar", figsize=(10,5))
plt.title("IPL Team Wins")
plt.xlabel("Teams")
plt.ylabel("Wins")
plt.show()
runs = deliveries.groupby("batsman")["batsman_runs"].sum().sort_values(ascending=False)
print("\nTop 10 Batsmen")
print(runs.head(10))
runs.head(10).plot(kind="bar", figsize=(10,5))
plt.title("Top 10 Run Scorers")
plt.xlabel("Players")
plt.ylabel("Runs")
plt.show()
wickets = deliveries[deliveries["player_dismissed"].notna()]
top_bowlers = wickets["bowler"].value_counts()
print("\nTop 10 Bowlers")
print(top_bowlers.head(10))
top_bowlers.head(10).plot(kind="bar", figsize=(10,5))
plt.title("Top 10 Wicket Takers")
plt.xlabel("Bowlers")
plt.ylabel("Wickets")
plt.show()
